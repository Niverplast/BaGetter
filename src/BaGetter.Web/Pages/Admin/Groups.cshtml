@page
@using System.Linq
@model BaGetter.Web.Pages.Admin.GroupsModel

@{
    ViewData["Title"] = "Groups & Permissions";
}

<div class="col-sm-12">
    <h1>Groups &amp; Permissions</h1>
    <hr class="breadcrumb-divider" />

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <h3>Create group</h3>
    <form method="post" asp-page-handler="CreateGroup">
        @Html.AntiForgeryToken()
        <div class="row">
            <div class="col-sm-6">
                <div class="form-group">
                    <label asp-for="NewGroupName">Group Name</label>
                    <input asp-for="NewGroupName" class="form-control" />
                    <span asp-validation-for="NewGroupName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="NewAppRoleValue">App Role Value (optional)</label>
                    <input asp-for="NewAppRoleValue" class="form-control" placeholder="Azure App Role value, e.g. TeamFrontend" />
                    <small class="text-muted">Enter an Azure App Role value to automatically sync members. Leave empty for manual membership management.</small>
                </div>
                <div class="form-group">
                    <label asp-for="NewDescription">Description</label>
                    <input asp-for="NewDescription" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary">Create Group</button>
            </div>
        </div>
    </form>

    <h3>Existing groups</h3>
    @if (Model.Groups.Count == 0)
    {
        <p>No groups found.</p>
    }
    else
    {
        @foreach (var group in Model.Groups)
        {
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h4 class="panel-title" style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                        @group.Name
                        @if (!string.IsNullOrEmpty(group.AppRoleValue))
                        {
                            <small class="text-muted">(Role: @group.AppRoleValue)</small>
                            <span class="label label-primary">Role-synced</span>
                        }
                        else
                        {
                            <span class="label label-default">Manual</span>
                        }
                        <form method="post" asp-page-handler="DeleteGroup" style="display:inline; margin-left:auto"
                              onsubmit="return confirm('Are you sure you want to delete this group? All memberships and permissions will be removed.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="groupId" value="@group.Id" />
                            <button type="submit" class="btn btn-xs btn-danger">Delete</button>
                        </form>
                    </h4>
                    @if (!string.IsNullOrEmpty(group.Description))
                    {
                        <p class="text-muted" style="margin-bottom:0">@group.Description</p>
                    }
                </div>
                <div class="panel-body">
                    @{
                        var isRoleLinked = !string.IsNullOrEmpty(group.AppRoleValue);
                    }
                    <h5>Members</h5>
                    @if (isRoleLinked)
                    {
                        <p class="text-muted"><em>Membership for Entra users is managed by Azure AD App Roles. Local users can be added manually.</em></p>
                    }
                    @if (group.UserGroups != null && group.UserGroups.Count > 0)
                    {
                        <table class="table table-condensed table-striped" style="margin-bottom:8px">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Provider</th>
                                    <th style="width:1%"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ug in group.UserGroups.OrderBy(u => u.User?.Username))
                                {
                                    var isEntraUser = ug.User?.AuthProvider == BaGetter.Core.Entities.AuthProvider.Entra;
                                    var canRemove = !isRoleLinked || !isEntraUser;
                                    <tr>
                                        <td>@ug.User?.Username</td>
                                        <td>
                                            <span class="label @(isEntraUser ? "label-info" : "label-default")">@ug.User?.AuthProvider</span>
                                            @if (isEntraUser && isRoleLinked)
                                            {
                                                <span class="label label-primary" style="font-size:9px" title="Synced via App Role '@group.AppRoleValue'">synced</span>
                                            }
                                        </td>
                                        <td>
                                            @if (canRemove)
                                            {
                                                <form method="post" asp-page-handler="RemoveUser">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="groupId" value="@group.Id" />
                                                    <input type="hidden" name="userId" value="@ug.UserId" />
                                                    <button type="submit" class="btn btn-xs btn-danger" title="Remove member">Remove</button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted">No members</p>
                    }

                    @{
                        var addableUsers = isRoleLinked
                            ? Model.AllUsers.Where(u => u.AuthProvider != BaGetter.Core.Entities.AuthProvider.Entra).ToList()
                            : Model.AllUsers;
                    }
                    @if (addableUsers.Any())
                    {
                        <form method="post" asp-page-handler="AddUser" class="form-inline" style="margin-top:8px">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="groupId" value="@group.Id" />
                            <div class="form-group">
                                <select name="userId" class="form-control input-sm">
                                    @foreach (var user in addableUsers)
                                    {
                                        <option value="@user.Id">@user.Username (@user.AuthProvider)</option>
                                    }
                                </select>
                            </div>
                            <button type="submit" class="btn btn-xs btn-success">Add Member</button>
                        </form>
                    }

                    <h5 style="margin-top:16px">Feed Permissions</h5>
                    @{
                        Model.GroupPermissions.TryGetValue(group.Id, out var groupPerm);
                    }
                    <form method="post" asp-page-handler="GrantPermission" class="form-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="principalId" value="@group.Id" />
                        <input type="hidden" name="principalType" value="@BaGetter.Core.Entities.PrincipalType.Group" />
                        <input type="hidden" name="feedId" value="default" />
                        <label class="checkbox-inline"><input type="checkbox" name="canPull" value="true" @(groupPerm?.CanPull == true ? "checked" : "") /> Pull</label>
                        <label class="checkbox-inline"><input type="checkbox" name="canPush" value="true" @(groupPerm?.CanPush == true ? "checked" : "") /> Push</label>
                        <button type="submit" class="btn btn-xs btn-primary">Set Permissions</button>
                        @if (Model.SavedGroupId == group.Id)
                        {
                            <span class="text-success" style="margin-left:6px" title="Permissions saved">&#10003;</span>
                        }
                    </form>
                </div>
            </div>
        }
    }
</div>
